{
  "manifest_version": 3,
  "name": "PageSurf",
  "version": "2.0",
  "description": "Chat with any webpage using AI. Compare responses from multiple models side by side.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.jpg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "http://localhost:8000/",
    "http://127.0.0.1:8000/"
  ]
}